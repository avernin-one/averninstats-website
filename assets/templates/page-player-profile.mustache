<div class=player-profile><div class=player-header><img src="/assets/images/player/body_{{name}}.png" alt="{{name}}" class=body-img onerror="this.style.display='none'"><div class=player-meta><h2>{{name}}</h2><div class=medals><span class="medal gold" title="Gold medals">🥇 {{medals.gold}}</span>
<span class="medal silver" title="Silver medals">🥈 {{medals.silver}}</span>
<span class="medal bronze" title="Bronze medals">🥉 {{medals.bronze}}</span></div></div></div><h3>Statistics</h3><table class="score-table stats-table"><thead><tr><th>Statistic<th>Count<tbody>{{#stats}}<tr><td>{{key}}<td class=score>{{value}}
{{/stats}}</table>{{#scores}}<h3>{{category}}</h3>{{#actions}}<table class=score-table><thead><tr><th>#<th>{{action}}<th>Count<tbody>{{#scores}}<tr><td class=rank>{{index}}<td>{{#names}}<div>{{.}}</div>{{/names}}<td class=score>{{score}}
{{/scores}}</table>{{/actions}}
{{/scores}}</div>